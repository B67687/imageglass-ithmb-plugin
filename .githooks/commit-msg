#!/usr/bin/env bash
# commit-msg — Enforce Conventional Commits format
# Install: place in .githooks/commit-msg and run:
#   git config core.hooksPath .githooks
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Conventional Commit pattern: type(scope)!: description
PATTERN='^(feat|fix|docs|refactor|test|chore|cleanup|perf)(\([a-z0-9_-]+\))?!?:\s.+$'

if ! echo "$COMMIT_MSG" | head -1 | grep -qE "$PATTERN"; then
    echo "ERROR: Commit message does not follow Conventional Commits format."
    echo ""
    echo "Expected: type(scope): description"
    echo "  Valid types: feat, fix, docs, refactor, test, chore, cleanup, perf"
    echo "  Examples:"
    echo "    feat(simd): add NEON dispatch for RGB565"
    echo "    fix(bitstream): correct CLCL nibble order"
    echo "    docs: update AGENTS.md with decoder pipeline"
    echo ""
    echo "Received:"
    head -1 "$COMMIT_MSG_FILE"
    exit 1
fi
